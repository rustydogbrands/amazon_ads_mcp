# OpenAPI processing
openapi/.cache/
# openapi/resources/ contents are regenerated by the private build pipeline
# (specs, manifests, media, transform sidecars). Ignore wholesale — any
# alias / input_transform rule placed here would be wiped on the next
# regen. Hand-authored rules that MUST survive live under
# openapi/overlays/ instead.
openapi/resources/*
# packages.json is the canonical namespace→prefix map consumed by both
# the runtime mount path AND by SidecarTransformMiddleware tool-name
# resolution. Source-controlled so middleware and mount always agree.
!openapi/resources/packages.json
# Keep the directory itself tracked so the negation above resolves.
!openapi/resources/.gitkeep

# openapi/overlays/ — hand-authored transform overlays (arg_aliases,
# input_transform blocks) that survive the private regen because they
# live outside openapi/resources/. See openapi/overlays/README.md.
!openapi/overlays/
!openapi/overlays/**

# Build directories
# .build/ contains essential build scripts - DO NOT IGNORE
build/
# src/amazon_ads_mcp/build/ is an internal package (refresh CLI, validators) — un-ignore it.
!src/amazon_ads_mcp/build/
!src/amazon_ads_mcp/build/*.py
*.tar.gz
*.whl

